# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ==================== Service ====================
# SERVICE_HOST: FastAPI / Uvicorn 綁定的網路位址
# 127.0.0.1 僅允許本機連線（建議）；改為 0.0.0.0 可允許外部連線（需搭配反向代理與認證）
SERVICE_HOST=127.0.0.1
# SERVICE_PORT: 後端 API 服務埠號
SERVICE_PORT=8000
# UVICORN_RELOAD: 是否啟用程式熱重載，開發可 true，正式環境建議 false
UVICORN_RELOAD=false

# ==================== Logging ====================
# LOG_TO_FILE: 是否將日誌寫入檔案
LOG_TO_FILE=true
# LOG_DIR: 日誌輸出目錄
LOG_DIR=./logs
# LOG_FILE_NAME: 主要日誌檔名
LOG_FILE_NAME=service.log
# LOG_BACKUP_COUNT: 保留幾份輪替後的舊日誌
LOG_BACKUP_COUNT=14
# UVICORN_ACCESS_LOG: 是否輸出 HTTP 存取日誌
UVICORN_ACCESS_LOG=true
# UVICORN_USE_COLORS: 終端機日誌是否使用彩色輸出
UVICORN_USE_COLORS=true

# ==================== Paths ====================
# HF_HOME: Hugging Face 模型、tokenizer、下載快取的根目錄
HF_HOME=./.cache/huggingface

# TIKTOKEN_RS_CACHE_DIR: TikToken / GPT-OSS 相關快取目錄，預設使用專案根目錄即可
TIKTOKEN_RS_CACHE_DIR=.

# LLAMA_SERVER_BINARY: llama-server 可執行檔完整路徑
# Linux 預設通常是 ./src/service/utils/llama.cpp/build/bin/llama-server
# Windows 預設通常是 ./src/service/utils/llama.cpp/build/bin/Release/llama-server.exe
# LLAMA_SERVER_BINARY=./src/service/utils/llama.cpp/build/bin/llama-server

# HF_TOKEN: 存取 Hugging Face 私有模型 / gated model 時使用的 Token
# HF_TOKEN=your_huggingface_token_here

# LLAMA_SERVER_URL: 外部已啟動的 llama-server API Base URL
# LLAMA_SERVER_URL=http://127.0.0.1:5001

# VLLM_SERVER_PROJECT_DIR: vLLM 隔離環境專案目錄
# VLLM_SERVER_PROJECT_DIR=./src/service/inference/engines/vllm_server

# REDIS_HOST: Redis 主機位址
# REDIS_HOST=127.0.0.1
# REDIS_PORT: Redis 埠號
# REDIS_PORT=6379
# REDIS_DB: Redis 資料庫編號
# REDIS_DB=0
