{
  "model_name": "meta-llama/Llama-3.1-70B",
  "method": "lora",
  "dataset_path": "path/to/your/dataset.jsonl",
  "output_dir": "finetune_output/llama_70b_lora_test",
  "offload_folder": "./deepspeed_offload",
  "lora_r": 8,
  "lora_alpha": 16,
  "lora_dropout": 0.05,
  "lora_target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "num_train_epochs": 10,
  "per_device_train_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.0002,
  "warmup_steps": 100,
  "logging_steps": 2,
  "save_steps": 500,
  "save_total_limit": 2,
  "max_seq_length": 2048,
  "text_field": "",
  "prompt_field": "prompt",
  "completion_field": "completion",
  "save_tokenizer": true,
  "use_deepspeed": true,
  "deepspeed_config": "",
  "deepspeed_profile": "zero3_offload_disk_disk",
  "use_sft_trainer": true,
  "packing": false
}